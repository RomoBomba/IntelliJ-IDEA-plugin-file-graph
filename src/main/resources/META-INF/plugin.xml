<idea-plugin>
    <id>com.filegraph</id>
    <name>File Graph</name>
    <vendor>Roman Shevtsov</vendor>

    <description><![CDATA[
    Interactive file dependency graph visualization for IntelliJ IDEA.
    Visualize how your project files are connected to each other.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true" supportsK1="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="File Graph"
                anchor="right"
                icon="AllIcons.Actions.ModuleDirectory"
                factoryClass="com.filegraph.toolwindow.GraphToolWindowFactory"
        />
    </extensions>
</idea-plugin>
