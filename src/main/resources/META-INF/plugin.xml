<idea-plugin>
    <id>com.filegraph</id>
    <name>File Graph</name>
    <version>1.0.0</version>
    <vendor>Roman Shevtsov</vendor>

    <description><![CDATA[
        <p>Интерактивный граф файлов проекта (Java/Kotlin).</p>
        <ul>
            <li>Подсветка соседей, выделение циклических зависимостей</li>
            <li>Zoom‑in/zoom‑out колесом, трекпадом и кнопками</li>
            <li>Двойной клик → открыть файл в редакторе</li>
            <li>Авто‑обновление при изменении файлов</li>
        </ul>
    ]]></description>

    <change-notes>
        <![CDATA[
        <h3>1.0.0</h3>
        <ul>
            <li>Первый публичный релиз</li>
            <li>Новый цветовой дизайн, плавный зум, кэш ресурсов</li>
        </ul>
        ]]>
    </change-notes>

    <idea-version since-build="261" />
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true" supportsK1="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="File Graph"
                anchor="right"
                icon="icons/fileGraph.svg"
                factoryClass="com.filegraph.toolwindow.GraphToolWindowFactory"/>
    </extensions>
</idea-plugin>
